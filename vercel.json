{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "pizzascript.com" }],
      "destination": "https://www.pizzascript.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/blog",
      "destination": "https://blog.pizzascript.com/"
    },
    {
      "source": "/blog/:path*",
      "destination": "https://blog.pizzascript.com/:path*"
    }
  ],
  "cleanUrls": true
}

